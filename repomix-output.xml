<file path="prisma/schema.prisma">
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ==================== Configuration-Driven UI — Core Models ====================

model Tablero {
  id          String   @id @default(cuid())
  empresaId   String
  nombre      String
  descripcion String?  // Subtítulo opcional visible en el header del tablero
  icono       String   @default("📊")
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa    Company    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  indicadores Indicador[]

  @@index([empresaId, orden])
}

model Indicador {
  id              String   @id @default(cuid())
  tableroId       String
  titulo          String
  descripcion     String?  // Descripción corta del KPI
  tipoGrafico     String   @default("bar")   // "bar" | "line" | "combo"
  unidad          String   @default("num")   // "$" | "%" | "num"
  metaGlobal      Float    @default(0)
  colorPrincipal  String   @default("#6366f1")
  esMejorMayor    Boolean  @default(true)    // true=Mayor es mejor, false=Menor es mejor
  orden           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tablero   Tablero         @relation(fields: [tableroId], references: [id], onDelete: Cascade)
  datos     IndicadorDato[]

  @@index([tableroId, orden])
}

model IndicadorDato {
  id                String   @id @default(cuid())
  indicadorId       String
  periodo           String   // "Week 1", "Enero", "Q1 2026", etc.
  valorLogrado      Float    @default(0)
  valorMetaEspecifica Float? // null = usar metaGlobal del indicador
  createdAt         DateTime @default(now())

  indicador Indicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)

  @@index([indicadorId])
  @@unique([indicadorId, periodo])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())

  users           User[]
  commercialKPIs  CommercialKPI[]
  operationKPIs   OperationKPI[]
  qualityKPIs     QualityKPI[]
  configurations  AppConfiguration[]
  tableros        Tablero[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("viewer") // 'superadmin', 'gerente', 'viewer'
  areas     String   @default("[]") // JSON array of areas: ["comercial", "operaciones", "calidad"]
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
}

model CommercialKPI {
  id             String   @id @default(cuid())
  period         String   // e.g. "2025-Q1", "2025-02"
  potenciales    Int      @default(0)
  presupuestos   Int      @default(0)
  monto          Float    @default(0)
  cumplimiento   Float    @default(0) // percentage
  createdAt      DateTime @default(now())
  uploadedAt     DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, period])
  @@index([companyId, createdAt])
}

model OperationKPI {
  id                   String   @id @default(cuid())
  period               String
  tiempoEfectivo       Float    @default(0) // percentage
  ordenesProgramadas   Int      @default(0)
  ordenesEjecutadas    Int      @default(0)
  cancelaciones        Int      @default(0)
  createdAt            DateTime @default(now())
  uploadedAt           DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, period])
  @@index([companyId, createdAt])
}

model QualityKPI {
  id                    String   @id @default(cuid())
  period                String
  nps                   Float    @default(0)
  cancelacionesTecnicas Int      @default(0)
  deficiencias          Int      @default(0)
  satisfaccion          Float    @default(0) // percentage
  createdAt             DateTime @default(now())
  uploadedAt            DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, period])
  @@index([companyId, createdAt])
}

// ==================== Configuration-Driven UI Models ====================

model AppConfiguration {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "global", "solvex", "el-mejor"
  config    String   @default("{}") // JSON configuration object
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
}

model MenuConfiguration {
  id        String   @id @default(cuid())
  menuKey   String   @unique // e.g. "comercial", "operaciones", "calidad"
  label     String   // Display name
  path      String   // Route path
  icon      String   @default("📊") // Emoji or icon name
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  minRole   String   @default("viewer") // Minimum role required
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KPIConfiguration {
  id          String   @id @default(cuid())
  area        String   // "comercial", "operaciones", "calidad"
  kpiKey      String   // Unique identifier for the KPI
  displayName String   // Display name
  goal        Float?   // Target/goal value
  unit        String   @default("") // Unit (%, $, #, etc.)
  chartType   String   @default("bar") // bar, line, pie, gauge
  color       String   @default("#3b82f6") // HEX color
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([area, kpiKey])
  @@index([area, enabled])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "superadmin", "gerente_comercial", "viewer"
  displayName String   // e.g. "Super Administrador", "Gerente Comercial"
  permissions String   @default("[]") // JSON array of permissions
  level       Int      @default(0) // 0=viewer, 1=gerente, 2=superadmin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
</file>

<file path="src/routes/auth.js">
const express = require('express');
const router = express.Router();
const bcrypt = require('bcryptjs');
const jwt = require('jsonwebtoken');
const db = require('../database/sqliteClient');

const JWT_SECRET = process.env.JWT_SECRET || 'solvex-secret-dev-key';

// POST /api/auth/login
router.post('/login', async (req, res) => {
    const { email, password } = req.body;

    if (!email || !password) {
        return res.status(400).json({ success: false, message: 'Email y contraseña requeridos.' });
    }

    try {
        const user = db.prepare('SELECT * FROM User WHERE email = ?').get(email);

        if (!user) {
            return res.status(401).json({ success: false, message: 'Credenciales inválidas.' });
        }

        const valid = await bcrypt.compare(password, user.password);
        if (!valid) {
            return res.status(401).json({ success: false, message: 'Credenciales inválidas.' });
        }

        const company = db.prepare('SELECT * FROM Company WHERE id = ?').get(user.companyId);

        // Parse areas from JSON string
        let areas = [];
        try {
            areas = JSON.parse(user.areas || '[]');
        } catch (e) {
            console.error('Error parsing user areas:', e);
        }

        const token = jwt.sign(
            { 
                userId: user.id, 
                email: user.email, 
                role: user.role, 
                companyId: user.companyId,
                areas 
            },
            JWT_SECRET,
            { expiresIn: '24h' }
        );

        res.json({
            success: true,
            token,
            user: { 
                id: user.id, 
                name: user.name, 
                email: user.email, 
                role: user.role,
                areas 
            },
            company: company ? { id: company.id, name: company.name, slug: company.slug } : null,
            permissions: {
                canAccessAdmin: user.role === 'superadmin',
                canManageKPIs: user.role === 'superadmin' || user.role === 'gerente',
                areas
            }
        });
    } catch (error) {
        console.error('Login error:', error);
        res.status(500).json({ success: false, message: 'Error interno del servidor.' });
    }
});

// GET /api/auth/me
router.get('/me', (req, res) => {
    const authHeader = req.headers.authorization;
    if (!authHeader?.startsWith('Bearer ')) {
        return res.status(401).json({ success: false, message: 'Token requerido.' });
    }
    try {
        const token = authHeader.split(' ')[1];
        const payload = jwt.verify(token, JWT_SECRET);
        const user = db.prepare('SELECT id, email, name, role, companyId, areas FROM User WHERE id = ?').get(payload.userId);
        if (!user) return res.status(404).json({ success: false, message: 'Usuario no encontrado.' });
        const company = db.prepare('SELECT id, name, slug FROM Company WHERE id = ?').get(user.companyId);
        
        // Parse areas
        let areas = [];
        try {
            areas = JSON.parse(user.areas || '[]');
        } catch (e) {
            console.error('Error parsing user areas:', e);
        }

        res.json({ 
            success: true, 
            user: { ...user, areas },
            company,
            permissions: {
                canAccessAdmin: user.role === 'superadmin',
                canManageKPIs: user.role === 'superadmin' || user.role === 'gerente',
                areas
            }
        });
    } catch {
        res.status(401).json({ success: false, message: 'Token inválido.' });
    }
});

module.exports = router;
