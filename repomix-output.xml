                            <span class="text-xs font-bold text-gray-500 uppercase">Results</span>
                            <span id="rowCount" class="text-xs text-gray-400">0 rows</span>
                        </div>
                        <div id="resultsTableContainer" class="flex-1 overflow-auto p-0">
                            <div class="flex items-center justify-center h-full text-gray-400 text-sm italic">
                                Run a query to see results
                            </div>
                        </div>
                    </div>
