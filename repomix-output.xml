// ─── Types ───────────────────────────────────────────────────────────────────
interface CSVRecord {
  empresa: string;
  area: string;
  kpi: string;
  semana: string;
  valor_logrado: number;
  valor_meta: number;
  unidad?: string;
}

export interface DashboardData {
  empresa: string;
  mes: string;
  comercial: {
    presupuestos_creados: { valor: number; meta: number };
    valor_presupuestos: { valor: number; meta: number };
  };
  operaciones: {
