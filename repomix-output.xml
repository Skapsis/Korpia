<file path="src/routes/config.js">
/**
 * Configuration-Driven UI — REST API
 *
 * GET  /api/config/:empresa_id      → JSON completo anidado (Tableros + KPIs + Datos)
 *
 * POST   /api/tableros              → Crear tablero
 * PUT    /api/tableros/:id          → Actualizar tablero
 * DELETE /api/tableros/:id          → Eliminar tablero
 *
 * POST   /api/indicadores           → Crear indicador
 * PUT    /api/indicadores/:id       → Actualizar indicador
 * DELETE /api/indicadores/:id       → Eliminar indicador
 *
 * POST   /api/datos                 → Insertar / actualizar dato(s) para un indicador
 * PUT    /api/datos/:id             → Actualizar un dato
 * DELETE /api/datos/:id             → Eliminar un dato
 */

const express = require('express');
const router = express.Router();
const prisma = require('../database/prismaClient');
const { authenticateToken, requireRole, normalizeRoleName } = require('../middleware/auth');

function isSuperAdmin(req) {
    return ['superadmin', 'admin'].includes(normalizeRoleName(req.user?.role || ''));
}

/** Verifica que el indicador (vía su tablero) pertenezca a la empresa del usuario */
async function requireIndicadorAccess(req, indicadorId, res) {
    const indicador = await prisma.indicador.findUnique({ where: { id: indicadorId }, select: { tableroId: true } });
    if (!indicador) return res.status(404).json({ success: false, message: 'Indicador no encontrado.' });
    return requireTableroAccess(req, indicador.tableroId, res);
}

/** Verifica que el tablero pertenezca a la empresa del usuario (salvo superadmin) */
async function requireTableroAccess(req, tableroId, res) {
    if (isSuperAdmin(req)) return null;
    const tablero = await prisma.tablero.findUnique({ where: { id: tableroId }, select: { empresaId: true } });
    if (!tablero) return res.status(404).json({ success: false, message: 'Tablero no encontrado.' });
    if (tablero.empresaId !== req.user.companyId) {
        return res.status(403).json({ success: false, message: 'No tienes acceso a este tablero.' });
    }
    return null;
}

/** Resuelve empresaId (slug o cuid) al id real de Company */
async function resolveEmpresaId(empresaId) {
    if (!empresaId) return null;
    const empresa = await prisma.company.findFirst({
        where: { OR: [{ id: empresaId }, { slug: empresaId }] },
    });
    return empresa?.id ?? null;
}

/** Helper reusable: obtiene el payload de empresa+tableros por empresaId */
async function buildConfigPayload(empresaId) {
    const empresa = await prisma.company.findUnique({ where: { id: empresaId } });
    if (!empresa) return null;
    const tableros = await prisma.tablero.findMany({
        where: { empresaId: empresa.id },
        orderBy: { orden: 'asc' },
        include: {
            indicadores: {
                orderBy: { orden: 'asc' },
                include: { datos: { orderBy: { periodo: 'asc' } } },
            },
        },
    });
    return {
        empresa: { id: empresa.id, nombre: empresa.name, slug: empresa.slug, logo: empresa.logo },
        tableros,
    };
}

// ────────────────────────────────────────────────────────────────────────────
// GET /api/companies  — listado de empresas (superadmin ve todas; otros solo la suya)
// ────────────────────────────────────────────────────────────────────────────
router.get('/companies', authenticateToken, async (req, res) => {
    try {
        const isSuperAdmin = ['superadmin', 'admin'].includes(
            String(req.user?.role || '').toLowerCase()
        );
        const companies = await prisma.company.findMany({
            select: { id: true, name: true, slug: true },
            orderBy: { name: 'asc' },
            ...(isSuperAdmin ? {} : { where: { id: req.user.companyId } }),
        });
        res.json({ success: true, companies });
    } catch (err) {
        console.error('GET /api/companies error:', err);
        res.status(500).json({ success: false, message: 'Error al obtener empresas.' });
    }
});

// ────────────────────────────────────────────────────────────────────────────
// GET /api/config/public/:empresa_id  — config por slug SIN auth (para demo/login simulado)
// ────────────────────────────────────────────────────────────────────────────
router.get('/config/public/:empresa_id', async (req, res) => {
    try {
        const { empresa_id } = req.params;
        const empresa = await prisma.company.findFirst({
            where: { OR: [{ id: empresa_id }, { slug: empresa_id }] },
        });
        if (!empresa) {
            return res.status(404).json({ success: false, message: 'Empresa no encontrada.' });
        }
        const payload = await buildConfigPayload(empresa.id);
        res.json({ success: true, ...payload });
    } catch (err) {
        console.error('GET /api/config/public error:', err);
        res.status(500).json({ success: false, message: 'Error al obtener configuración.' });
    }
});

// ────────────────────────────────────────────────────────────────────────────
// GET /api/config  — config completa para el usuario autenticado (usa JWT)
// ────────────────────────────────────────────────────────────────────────────
router.get('/config', authenticateToken, async (req, res) => {
    try {
        const payload = await buildConfigPayload(req.user.companyId);
        if (!payload) {
            return res.status(404).json({ success: false, message: 'Empresa del usuario no encontrada.' });
        }
        res.json({ success: true, ...payload });
    } catch (err) {
        console.error('GET /api/config error:', err);
        res.status(500).json({ success: false, message: 'Error al obtener configuración.' });
    }
});

// ────────────────────────────────────────────────────────────────────────────
// GET /api/config/:empresa_id  — configuración anidada completa
// ────────────────────────────────────────────────────────────────────────────
router.get('/config/:empresa_id', authenticateToken, async (req, res) => {
    try {
        const { empresa_id } = req.params;

        // Aceptar tanto el id (cuid) como el slug de la empresa
        const empresa = await prisma.company.findFirst({
            where: { OR: [{ id: empresa_id }, { slug: empresa_id }] },
        });

        if (!empresa) {
            return res.status(404).json({ success: false, message: 'Empresa no encontrada.' });
        }

        const tableros = await prisma.tablero.findMany({
            where: { empresaId: empresa.id },
            orderBy: { orden: 'asc' },
            include: {
                indicadores: {
                    orderBy: { orden: 'asc' },
                    include: {
                        datos: { orderBy: { periodo: 'asc' } },
                    },
                },
            },
        });

        res.json({
            success: true,
            empresa: { id: empresa.id, nombre: empresa.name, slug: empresa.slug, logo: empresa.logo },
            tableros,
        });
    } catch (err) {
        console.error('GET /api/config error:', err);
        res.status(500).json({ success: false, message: 'Error al obtener configuración.' });
    }
});

// ────────────────────────────────────────────────────────────────────────────
// TABLEROS
// ────────────────────────────────────────────────────────────────────────────

// POST /api/tableros
router.post('/tableros', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const { empresaId, nombre, icono, orden } = req.body;
        if (!empresaId || !nombre) {
            return res.status(400).json({ success: false, message: 'empresaId y nombre son requeridos.' });
        }

        const resolvedEmpresaId = await resolveEmpresaId(empresaId);
        if (!resolvedEmpresaId) {
            return res.status(404).json({ success: false, message: 'Empresa no encontrada.' });
        }
        if (!isSuperAdmin(req) && resolvedEmpresaId !== req.user.companyId) {
            return res.status(403).json({ success: false, message: 'Solo puedes crear tableros para tu empresa.' });
        }

        const tablero = await prisma.tablero.create({
            data: {
                empresaId: resolvedEmpresaId,
                nombre,
                icono: icono || '📊',
                orden: orden ?? 0,
            },
        });

        res.status(201).json({ success: true, tablero });
    } catch (err) {
        console.error('POST /api/tableros error:', err);
        res.status(500).json({ success: false, message: 'Error al crear tablero.' });
    }
});

// PUT /api/tableros/:id
router.put('/tableros/:id', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const { id } = req.params;
        const accessErr = await requireTableroAccess(req, id, res);
        if (accessErr) return accessErr;

        const { nombre, icono, orden } = req.body;

        const tablero = await prisma.tablero.update({
            where: { id },
            data: {
                ...(nombre !== undefined && { nombre }),
                ...(icono !== undefined && { icono }),
                ...(orden !== undefined && { orden }),
            },
        });

        res.json({ success: true, tablero });
    } catch (err) {
        if (err.code === 'P2025') return res.status(404).json({ success: false, message: 'Tablero no encontrado.' });
        console.error('PUT /api/tableros/:id error:', err);
        res.status(500).json({ success: false, message: 'Error al actualizar tablero.' });
    }
});

// DELETE /api/tableros/:id
router.delete('/tableros/:id', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const { id } = req.params;
        const accessErr = await requireTableroAccess(req, id, res);
        if (accessErr) return accessErr;

        await prisma.tablero.delete({ where: { id } });
        res.json({ success: true, message: 'Tablero eliminado exitosamente.' });
    } catch (err) {
        if (err.code === 'P2025') return res.status(404).json({ success: false, message: 'Tablero no encontrado.' });
        console.error('DELETE /api/tableros/:id error:', err);
        res.status(500).json({ success: false, message: 'Error al eliminar tablero.' });
    }
});

// GET /api/tableros?empresaId=xxx  — listado simple para el selector del admin (empresaId puede ser slug o cuid)
router.get('/tableros', authenticateToken, async (req, res) => {
    try {
        const { empresaId } = req.query;
        let where = {};
        if (empresaId) {
            const resolvedId = await resolveEmpresaId(empresaId);
            if (resolvedId) where = { empresaId: resolvedId };
        }
        if (!isSuperAdmin(req)) {
            if (Object.keys(where).length === 0) {
                where = { empresaId: req.user.companyId };
            } else if (where.empresaId && where.empresaId !== req.user.companyId) {
                return res.status(403).json({ success: false, message: 'No tienes acceso a los tableros de esta empresa.' });
            }
        }
        const tableros = await prisma.tablero.findMany({
            where,
            orderBy: { orden: 'asc' },
            include: {
                indicadores: {
                    orderBy: { orden: 'asc' },
                    include: { datos: { orderBy: { periodo: 'asc' } } },
                },
            },
        });
        res.json({ success: true, tableros });
    } catch (err) {
        console.error('GET /api/tableros error:', err);
        res.status(500).json({ success: false, message: 'Error al obtener tableros.' });
    }
});

// ────────────────────────────────────────────────────────────────────────────
// INDICADORES
// ────────────────────────────────────────────────────────────────────────────

// POST /api/indicadores
router.post('/indicadores', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const { tableroId, titulo, tipoGrafico, unidad, metaGlobal, colorPrincipal, esMejorMayor, orden } = req.body;

        if (!tableroId || !titulo) {
            return res.status(400).json({ success: false, message: 'tableroId y titulo son requeridos.' });
        }
        const accessErr = await requireTableroAccess(req, tableroId, res);
        if (accessErr) return accessErr;

        const indicador = await prisma.indicador.create({
            data: {
                tableroId,
                titulo,
                tipoGrafico: tipoGrafico || 'bar',
                unidad: unidad || 'num',
                metaGlobal: metaGlobal ?? 0,
                colorPrincipal: colorPrincipal || '#6366f1',
                esMejorMayor: esMejorMayor !== undefined ? Boolean(esMejorMayor) : true,
                orden: orden ?? 0,
            },
        });

        res.status(201).json({ success: true, indicador });
    } catch (err) {
        console.error('POST /api/indicadores error:', err);
        res.status(500).json({ success: false, message: 'Error al crear indicador.' });
    }
});

// PUT /api/indicadores/:id
router.put('/indicadores/:id', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const { id } = req.params;
        const indicadorExistente = await prisma.indicador.findUnique({ where: { id }, select: { tableroId: true } });
        if (!indicadorExistente) return res.status(404).json({ success: false, message: 'Indicador no encontrado.' });
        const accessErr = await requireTableroAccess(req, indicadorExistente.tableroId, res);
        if (accessErr) return accessErr;

        const { titulo, tipoGrafico, unidad, metaGlobal, colorPrincipal, esMejorMayor, orden, tableroId } = req.body;

        const indicador = await prisma.indicador.update({
            where: { id },
            data: {
                ...(titulo !== undefined && { titulo }),
                ...(tipoGrafico !== undefined && { tipoGrafico }),
                ...(unidad !== undefined && { unidad }),
                ...(metaGlobal !== undefined && { metaGlobal: Number(metaGlobal) }),
                ...(colorPrincipal !== undefined && { colorPrincipal }),
                ...(esMejorMayor !== undefined && { esMejorMayor: Boolean(esMejorMayor) }),
                ...(orden !== undefined && { orden: Number(orden) }),
                ...(tableroId !== undefined && { tableroId }),
            },
        });

        res.json({ success: true, indicador });
    } catch (err) {
        if (err.code === 'P2025') return res.status(404).json({ success: false, message: 'Indicador no encontrado.' });
        console.error('PUT /api/indicadores/:id error:', err);
        res.status(500).json({ success: false, message: 'Error al actualizar indicador.' });
    }
});

// DELETE /api/indicadores/:id
router.delete('/indicadores/:id', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const { id } = req.params;
        const indicadorExistente = await prisma.indicador.findUnique({ where: { id }, select: { tableroId: true } });
        if (!indicadorExistente) return res.status(404).json({ success: false, message: 'Indicador no encontrado.' });
        const accessErr = await requireTableroAccess(req, indicadorExistente.tableroId, res);
        if (accessErr) return accessErr;

        await prisma.indicador.delete({ where: { id } });
        res.json({ success: true, message: 'Indicador eliminado exitosamente.' });
    } catch (err) {
        if (err.code === 'P2025') return res.status(404).json({ success: false, message: 'Indicador no encontrado.' });
        console.error('DELETE /api/indicadores/:id error:', err);
        res.status(500).json({ success: false, message: 'Error al eliminar indicador.' });
    }
});

// GET /api/indicadores/:id  — incluye datos
router.get('/indicadores/:id', authenticateToken, async (req, res) => {
    try {
        const accessErr = await requireIndicadorAccess(req, req.params.id, res);
        if (accessErr) return accessErr;

        const indicador = await prisma.indicador.findUnique({
            where: { id: req.params.id },
            include: { datos: { orderBy: { periodo: 'asc' } } },
        });
        if (!indicador) return res.status(404).json({ success: false, message: 'Indicador no encontrado.' });
        res.json({ success: true, indicador });
    } catch (err) {
        console.error('GET /api/indicadores/:id error:', err);
        res.status(500).json({ success: false, message: 'Error al obtener indicador.' });
    }
});

// ────────────────────────────────────────────────────────────────────────────
// DATOS (IndicadorDato)
// ────────────────────────────────────────────────────────────────────────────

// POST /api/datos  — upsert masivo: recibe array de { indicadorId, periodo, valorLogrado, valorMetaEspecifica? }
router.post('/datos', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        let registros = req.body;
        if (!Array.isArray(registros)) registros = [registros];

        if (!registros.length) {
            return res.status(400).json({ success: false, message: 'Se requiere al menos un dato.' });
        }
        const indicadorIds = [...new Set(registros.map((r) => r.indicadorId).filter(Boolean))];
        for (const indicadorId of indicadorIds) {
            const accessErr = await requireIndicadorAccess(req, indicadorId, res);
            if (accessErr) return accessErr;
        }

        const created = [];
        for (const r of registros) {
            const { indicadorId, periodo, valorLogrado, valorMetaEspecifica } = r;
            if (!indicadorId || !periodo) continue;

            const dato = await prisma.indicadorDato.upsert({
                where: { indicadorId_periodo: { indicadorId, periodo } },
                create: {
                    indicadorId,
                    periodo,
                    valorLogrado: Number(valorLogrado ?? 0),
                    valorMetaEspecifica: valorMetaEspecifica != null ? Number(valorMetaEspecifica) : null,
                },
                update: {
                    valorLogrado: Number(valorLogrado ?? 0),
                    valorMetaEspecifica: valorMetaEspecifica != null ? Number(valorMetaEspecifica) : null,
                },
            });
            created.push(dato);
        }

        res.status(201).json({ success: true, count: created.length, datos: created });
    } catch (err) {
        console.error('POST /api/datos error:', err);
        res.status(500).json({ success: false, message: 'Error al guardar datos.' });
    }
});

// PUT /api/datos/:id
router.put('/datos/:id', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const { id } = req.params;
        const datoExistente = await prisma.indicadorDato.findUnique({ where: { id }, select: { indicadorId: true } });
        if (!datoExistente) return res.status(404).json({ success: false, message: 'Dato no encontrado.' });
        const accessErr = await requireIndicadorAccess(req, datoExistente.indicadorId, res);
        if (accessErr) return accessErr;

        const { periodo, valorLogrado, valorMetaEspecifica } = req.body;

        const dato = await prisma.indicadorDato.update({
            where: { id },
            data: {
                ...(periodo !== undefined && { periodo }),
                ...(valorLogrado !== undefined && { valorLogrado: Number(valorLogrado) }),
                ...(valorMetaEspecifica !== undefined && {
                    valorMetaEspecifica: valorMetaEspecifica != null ? Number(valorMetaEspecifica) : null,
                }),
            },
        });

        res.json({ success: true, dato });
    } catch (err) {
        if (err.code === 'P2025') return res.status(404).json({ success: false, message: 'Dato no encontrado.' });
        console.error('PUT /api/datos/:id error:', err);
        res.status(500).json({ success: false, message: 'Error al actualizar dato.' });
    }
});

// DELETE /api/datos/:id
router.delete('/datos/:id', authenticateToken, requireRole(['SUPERADMIN', 'MANAGER']), async (req, res) => {
    try {
        const datoExistente = await prisma.indicadorDato.findUnique({ where: { id: req.params.id }, select: { indicadorId: true } });
        if (!datoExistente) return res.status(404).json({ success: false, message: 'Dato no encontrado.' });
        const accessErr = await requireIndicadorAccess(req, datoExistente.indicadorId, res);
        if (accessErr) return accessErr;

        await prisma.indicadorDato.delete({ where: { id: req.params.id } });
        res.json({ success: true, message: 'Dato eliminado.' });
    } catch (err) {
        if (err.code === 'P2025') return res.status(404).json({ success: false, message: 'Dato no encontrado.' });
        console.error('DELETE /api/datos/:id error:', err);
        res.status(500).json({ success: false, message: 'Error al eliminar dato.' });
    }
});

module.exports = router;
</file>

