    <script>
        if (!localStorage.getItem('solvex_token')) {
            window.location.href = '/login.html';
        }

        const userName = JSON.parse(localStorage.getItem('solvex_user'))?.name || 'Admin';
        document.getElementById('userName').textContent = userName;

        async function fetchSchema() {
            try {
                const response = await fetch('/api/query/schema');
                const data = await response.json();
                if (data.success) {
                    const list = document.getElementById('schemaList');
                    list.innerHTML = '';
                    data.tables.forEach(table => {
                        const div = document.createElement('div');
                        div.className = 'flex items-center gap-2 p-2 hover:bg-gray-50 rounded-lg cursor-pointer group shadow-sm border border-transparent hover:border-gray-100';
                        div.innerHTML = `
                            <span class="material-symbols-outlined text-gray-400 group-hover:text-primary transition-colors">table_chart</span>
                            <span class="text-sm font-medium text-text-secondary group-hover:text-text-main">${table}</span>
                        `;
                        div.onclick = () => {
                            document.getElementById('sqlInput').value = `SELECT * FROM ${table} LIMIT 20;`;
                        };
                        list.appendChild(div);
                    });
                }
            } catch (err) {
                console.error("Error fetching schema", err);
            }
        }

        async function runQuery() {
            const query = document.getElementById('sqlInput').value;
            if (!query.trim()) return;

            const container = document.getElementById('resultsTableContainer');
            container.innerHTML = '<div class="flex items-center justify-center h-full"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div></div>';

            try {
                const response = await fetch('/api/query', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query })
                });
                const data = await response.json();

                if (data.success) {
                    renderResults(data.data || []);
                    document.getElementById('rowCount').textContent = `${data.data?.length || 0} rows`;
                } else {
                    container.innerHTML = `<div class="p-6 text-red-500 font-medium bg-red-50 border border-red-100 m-4 rounded-xl flex items-start gap-2">
                        <span class="material-symbols-outlined">error</span>
                        <div>
                            <div class="font-bold">Query Error</div>
                            <div class="text-sm opacity-80 mt-1">${data.message}</div>
                        </div>
                    </div>`;
                }
            } catch (err) {
                container.innerHTML = `<div class="p-4 text-red-500">Error connecting to server.</div>`;
            }
        }

        function renderResults(data) {
            const container = document.getElementById('resultsTableContainer');
            if (data.length === 0) {
                container.innerHTML = '<div class="p-8 text-center text-gray-400 italic">Query executed successfully but returned no results.</div>';
                return;
            }

            const columns = Object.keys(data[0]);
            let html = `<table class="w-full text-left text-sm border-collapse">
                <thead class="bg-gray-50 sticky top-0 border-b border-border-color shadow-sm">
                    <tr>
                        ${columns.map(col => `<th class="px-4 py-3 font-semibold text-text-secondary uppercase tracking-wider text-[11px] border-r border-border-color last:border-0">${col}</th>`).join('')}
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    ${data.map(row => `
                        <tr class="hover:bg-gray-50 transition-colors">
                            ${columns.map(col => `<td class="px-4 py-3 text-text-main border-r border-gray-50 last:border-0">${row[col] !== null ? row[col] : '<span class="text-gray-300">null</span>'}</td>`).join('')}
                        </tr>
                    `).join('')}
                </tbody>
            </table>`;
            container.innerHTML = html;
        }

        function logout() {
            localStorage.removeItem('solvex_token');
            localStorage.removeItem('solvex_user');
            window.location.href = '/login.html';
        }

        fetchSchema();
    </script>
</body>

</html>
</file>

