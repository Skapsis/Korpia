                                        label={{ value: 'Millones ($M)', angle: -90, position: 'insideLeft', style: { fontSize: 12, fill: '#64748b' } }}
                                    />
                                    <Tooltip content={<CustomTooltip type="currency" />} />
                                    <Legend 
