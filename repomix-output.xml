    <script>
        async function loadDashboardData() {
            try {
                // Fetch KPIs from SQL backend
                const revenueQuery = "SELECT SUM(revenue) as total FROM commercial_sales";
                const countQuery = "SELECT COUNT(*) as count FROM commercial_sales";

                const [revRes, countRes] = await Promise.all([
                    fetch('/api/query', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ query: revenueQuery })
                    }).then(r => r.json()),
                    fetch('/api/query', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ query: countQuery })
                    }).then(r => r.json())
                ]);

                if (revRes.success && revRes.data.length > 0) {
                    const total = revRes.data[0].total || 0;
                    document.getElementById('kpi-valor').textContent = '$' + (total / 1000000).toFixed(1) + 'M';
                }

                if (countRes.success && countRes.data.length > 0) {
                    const count = countRes.data[0].count || 0;
                    const meta = 80;
                    document.getElementById('kpi-presupuestos').innerHTML = `${count} <span class="text-lg text-slate-400 font-normal">/ ${meta}</span>`;

                    const progress = Math.min((count / meta) * 100, 100);
                    document.getElementById('kpi-presupuestos-progress-text').textContent = progress.toFixed(1) + '%';
                    document.getElementById('kpi-presupuestos-progress-bar').style.width = progress + '%';
                }

                // Mocking trending potentials for visual
                document.getElementById('kpi-potenciales').textContent = '92%';
                document.getElementById('kpi-potenciales-trend').textContent = '3.8%';

            } catch (err) {
                console.error("Error loading dashboard data", err);
            }
        }

        loadDashboardData();
    </script>
</body>

</html>
