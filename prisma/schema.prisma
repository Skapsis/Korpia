// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== BI Dinámico (Configuration-Driven) — Modelos principales ====================
// Mapeo conceptual: Empresa → Company | Usuario → User | Tablero | Indicador | DatoKPI

model Tablero {
  id          String   @id @default(cuid())
  empresaId   String
  nombre      String
  descripcion String?  // Subtítulo opcional visible en el header del tablero
  icono       String   @default("📊")
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa    Company    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  indicadores Indicador[]

  @@index([empresaId, orden])
}

model Indicador {
  id              String   @id @default(cuid())
  tableroId       String
  titulo          String
  descripcion     String?  // Descripción corta del KPI
  tipoGrafico     String   @default("bar")   // "bar" | "line" | "combo"
  unidad          String   @default("num")   // "$" | "%" | "num"
  metaGlobal      Float    @default(0)
  colorPrincipal  String   @default("#6366f1")
  esMejorMayor    Boolean  @default(true)    // true=Mayor es mejor, false=Menor es mejor
  orden               Int      @default(0)
  gridX               Int      @default(0)  // Posición en grid del dashboard
  gridY               Int      @default(0)
  gridW               Int      @default(4)  // Ancho en columnas del grid
  gridH               Int      @default(3)  // Alto en filas del grid
  usaDatosDinamicos   Boolean  @default(false)  // true = ejecutar consultaSql en vivo (SQL Server)
  cadenaConexion     String?  // Cadena de conexión para motor SQL en vivo (ej. SQL Server)
  fuenteDatosId      String?  // Opcional: origen externo para sincronización
  consultaSql         String?  // Query SQL (debe retornar periodo, logrado, opcionalmente meta)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tablero      Tablero       @relation(fields: [tableroId], references: [id], onDelete: Cascade)
  fuenteDatos  FuenteDatos?  @relation(fields: [fuenteDatosId], references: [id], onDelete: SetNull)
  datos        DatoKPI[]

  @@index([tableroId, orden])
  @@index([fuenteDatosId])
}

/// Fuente de datos externa (Postgres, MySQL, etc.) para sincronización de indicadores.
model FuenteDatos {
  id              String   @id @default(cuid())
  empresaId       String
  nombre          String   // Ej. "Warehouse Postgres", "CRM MySQL"
  tipo            String   // 'POSTGRES' | 'MYSQL'
  cadenaConexion  String   // postgresql://user:pass@host:5432/db o mysql2://...
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  empresa     Company     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  indicadores Indicador[]

  @@index([empresaId])
}

/// Datos por periodo de un Indicador (valor logrado y meta específica opcional).
model DatoKPI {
  id                  String   @id @default(cuid())
  indicadorId         String
  periodo             String   // "Week 1", "Enero", "Q1 2026", etc.
  valorLogrado        Float    @default(0)
  valorMetaEspecifica Float?   // null = usar metaGlobal del indicador
  createdAt           DateTime @default(now())

  indicador Indicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)

  @@index([indicadorId])
  @@unique([indicadorId, periodo])
  @@map("IndicadorDato") // Mantiene nombre de tabla existente en SQLite (sin pérdida de datos)
}

/// Empresa (id, nombre → name, slug)
model Company {
  id        String   @id @default(cuid())
  name      String   // nombre
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())

  users           User[]
  commercialKPIs  CommercialKPI[]
  operationKPIs   OperationKPI[]
  qualityKPIs     QualityKPI[]
  configurations  AppConfiguration[]
  tableros        Tablero[]
  fuentesDatos    FuenteDatos[]
}

/// Usuario (id, email, password, role, empresaId → companyId)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("viewer") // 'superadmin', 'gerente', 'viewer'
  areas     String   @default("[]") // JSON array of areas: ["comercial", "operaciones", "calidad"]
  createdAt DateTime @default(now())

  companyId String   // empresaId
  company   Company @relation(fields: [companyId], references: [id])
}

model CommercialKPI {
  id             String   @id @default(cuid())
  period         String   // e.g. "2025-Q1", "2025-02"
  potenciales    Int      @default(0)
  presupuestos   Int      @default(0)
  monto          Float    @default(0)
  cumplimiento   Float    @default(0) // percentage
  createdAt      DateTime @default(now())
  uploadedAt     DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, period])
  @@index([companyId, createdAt])
}

model OperationKPI {
  id                   String   @id @default(cuid())
  period               String
  tiempoEfectivo       Float    @default(0) // percentage
  ordenesProgramadas   Int      @default(0)
  ordenesEjecutadas    Int      @default(0)
  cancelaciones        Int      @default(0)
  createdAt            DateTime @default(now())
  uploadedAt           DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, period])
  @@index([companyId, createdAt])
}

model QualityKPI {
  id                    String   @id @default(cuid())
  period                String
  nps                   Float    @default(0)
  cancelacionesTecnicas Int      @default(0)
  deficiencias          Int      @default(0)
  satisfaccion          Float    @default(0) // percentage
  createdAt             DateTime @default(now())
  uploadedAt            DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId, period])
  @@index([companyId, createdAt])
}

// ==================== Configuration-Driven UI Models ====================

model AppConfiguration {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "global", "solvex", "el-mejor"
  config    String   @default("{}") // JSON configuration object
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
}

model MenuConfiguration {
  id        String   @id @default(cuid())
  menuKey   String   @unique // e.g. "comercial", "operaciones", "calidad"
  label     String   // Display name
  path      String   // Route path
  icon      String   @default("📊") // Emoji or icon name
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  minRole   String   @default("viewer") // Minimum role required
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KPIConfiguration {
  id          String   @id @default(cuid())
  area        String   // "comercial", "operaciones", "calidad"
  kpiKey      String   // Unique identifier for the KPI
  displayName String   // Display name
  goal        Float?   // Target/goal value
  unit        String   @default("") // Unit (%, $, #, etc.)
  chartType   String   @default("bar") // bar, line, pie, gauge
  color       String   @default("#3b82f6") // HEX color
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([area, kpiKey])
  @@index([area, enabled])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "superadmin", "gerente_comercial", "viewer"
  displayName String   // e.g. "Super Administrador", "Gerente Comercial"
  permissions String   @default("[]") // JSON array of permissions
  level       Int      @default(0) // 0=viewer, 1=gerente, 2=superadmin
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
