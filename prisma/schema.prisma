generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String
  mustChangePassword Boolean   @default(true)
  role          String         @default("USER")
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  folderAccess  FolderAccess[]
  favoriteDashboards DashboardLink[] @relation("UserFavoriteDashboards")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Group {
  id                 String                 @id @default(cuid())
  name               String                 @unique
  description        String?
  users              User[]
  dashboardAccess    GroupDashboardAccess[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model GroupDashboardAccess {
  id             String        @id @default(cuid())
  groupId        String
  dashboardId     String
  group          Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  dashboard   DashboardLink @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([groupId, dashboardId])
  @@index([groupId])
  @@index([dashboardId])
}

model Folder {
  id             String          @id @default(cuid())
  name           String
  description    String?
  order          Int             @default(0)
  parentId       String?
  parent         Folder?         @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Folder[]        @relation("FolderHierarchy")
  folderAccess   FolderAccess[]
  dashboardLinks DashboardLink[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([parentId])
}

model FolderAccess {
  id        String   @id @default(cuid())
  userId    String
  folderId  String
  role      String   @default("viewer") // viewer | editor | admin
  isDenied  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, folderId])
  @@index([userId])
  @@index([folderId])
}

model DashboardLink {
  id                   String                 @id @default(cuid())
  folderId             String
  title                String
  description          String?
  url                  String   // URL del dashboard en Superset o externo
  order                Int      @default(0)
  kpiValue             String?  // Ej: "$1.2M"
  kpiTrend             String?  // Ej: "+15%"
  folder               Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  groupDashboardAccess GroupDashboardAccess[]
  favoritedBy          User[]                 @relation("UserFavoriteDashboards")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([folderId])
}
